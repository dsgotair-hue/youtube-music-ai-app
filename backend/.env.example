# Required: OpenAI API key for the LangChain/LangGraph agent
OPENAI_API_KEY=your_openai_api_key_here

# Required: YouTube Data API v3 key for music search
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Frontend origin for CORS (defaults to http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173
